# ── Environment Configuration ──
# Copy this file to .env and update values for your deployment

# ── API Configuration ──
ENVIRONMENT=development
LOG_LEVEL=info
DEBUG=true

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Database ──
DATABASE_URL=postgresql://nutrition_user:secure_password@localhost:5432/nutrition_db
DB_ECHO=false

# ── Security ──
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# ── Redis Cache ──
REDIS_URL=redis://localhost:6379/0
CACHE_EXPIRATION_SECONDS=3600

# ── MLflow ──
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=nutrition-recommendations
MLFLOW_BACKEND_STORE_URI=postgresql://nutrition_user:secure_password@localhost:5432/mlflow

# ── File Paths ──
MODEL_PATH=models/nutrition_model.pkl
DATA_PATH=Data/ObesityDataSet_raw_and_data_sinthetic.csv
REPORTS_PATH=reports/

# ── Feature Flags ──
ENABLE_DASHBOARD=true
ENABLE_ADMIN_API=false
ENABLE_ANALYTICS=true

# ── External APIs ──
# USDA_API_KEY=your-key-here
# WEATHER_API_KEY=your-key-here

# ── Email ──
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@nutritionrec.com

# ── Logging ──
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ── Docker ──
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=nutrition-recommender
DOCKER_IMAGE_TAG=latest
